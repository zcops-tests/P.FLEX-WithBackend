model Incident {
  id                    String    @id @default(uuid()) @db.VarChar(36)
  code                  String    @unique @db.VarChar(50)
  title                 String    @db.VarChar(200)
  description           String?   @db.Text
  priority              String    @db.VarChar(50) // HIGH, MEDIUM, LOW
  type                  String    @db.VarChar(50) // QUALITY, SAFETY, MACHINERY, MATERIAL, OTHER
  status                String    @default("OPEN") @db.VarChar(50) // OPEN, ANALYSIS, CORRECTIVE_ACTION, CLOSED
  work_order_id         String?   @db.VarChar(36)
  machine_id            String?   @db.VarChar(36)
  reported_by_user_id   String    @db.VarChar(36)
  assigned_to_user_id   String?   @db.VarChar(36)
  reported_at           DateTime  @db.DateTime(3)
  root_cause            String?   @db.Text
  machine_code_snapshot String?   @db.VarChar(50)
  ot_number_snapshot    String?   @db.VarChar(50)
  row_version           BigInt    @default(1)
  created_at            DateTime  @default(now()) @db.DateTime(3)
  updated_at            DateTime  @updatedAt @db.DateTime(3)
  deleted_at            DateTime? @db.DateTime(3)

  work_order  WorkOrder?   @relation(fields: [work_order_id], references: [id])
  machine     Machine?     @relation(fields: [machine_id], references: [id])
  reportedBy  User         @relation("ReportedBy", fields: [reported_by_user_id], references: [id])
  assignedTo  User?        @relation("AssignedTo", fields: [assigned_to_user_id], references: [id])
  capaActions CapaAction[]

  @@index([reported_at])
  @@index([status])
  @@index([updated_at])
  @@index([deleted_at])
  @@map("incidents")
}

model CapaAction {
  id                  String    @id @default(uuid()) @db.VarChar(36)
  incident_id         String    @db.VarChar(36)
  description         String    @db.Text
  action_type         String    @db.VarChar(50) // CORRECTIVE, PREVENTIVE
  responsible_user_id String    @db.VarChar(36)
  deadline            DateTime  @db.Date
  completed           Boolean   @default(false)
  completed_at        DateTime? @db.DateTime(3)
  row_version         BigInt    @default(1)
  created_at          DateTime  @default(now()) @db.DateTime(3)
  updated_at          DateTime  @updatedAt @db.DateTime(3)
  deleted_at          DateTime? @db.DateTime(3)

  incident    Incident @relation(fields: [incident_id], references: [id])
  responsible User     @relation(fields: [responsible_user_id], references: [id])

  @@index([deadline])
  @@index([updated_at])
  @@index([deleted_at])
  @@map("capa_actions")
}

