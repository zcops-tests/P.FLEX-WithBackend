// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// =========================================================
// 1. ADMINISTRACIÓN, SEGURIDAD Y CATÁLOGOS
// =========================================================

model Area {
  id          String    @id @default(uuid()) @db.VarChar(36)
  code        String    @unique @db.VarChar(50)
  name        String    @db.VarChar(100)
  description String?   @db.Text
  active      Boolean   @default(true)
  row_version BigInt    @default(1)
  created_at  DateTime  @default(now()) @db.DateTime(3)
  updated_at  DateTime  @updatedAt @db.DateTime(3)
  deleted_at  DateTime? @db.DateTime(3)

  machines      Machine[]
  assignedUsers UserAssignedArea[]

  @@map("areas")
}

model Permission {
  id          String    @id @default(uuid()) @db.VarChar(36)
  code        String    @unique @db.VarChar(100)
  name        String    @db.VarChar(100)
  description String?   @db.Text
  row_version BigInt    @default(1)
  created_at  DateTime  @default(now()) @db.DateTime(3)
  updated_at  DateTime  @updatedAt @db.DateTime(3)
  deleted_at  DateTime? @db.DateTime(3)

  roles RolePermission[]

  @@map("permissions")
}

model Role {
  id          String    @id @default(uuid()) @db.VarChar(36)
  code        String    @unique @db.VarChar(50)
  name        String    @db.VarChar(100)
  description String?   @db.Text
  active      Boolean   @default(true)
  row_version BigInt    @default(1)
  created_at  DateTime  @default(now()) @db.DateTime(3)
  updated_at  DateTime  @updatedAt @db.DateTime(3)
  deleted_at  DateTime? @db.DateTime(3)

  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model RolePermission {
  id            String    @id @default(uuid()) @db.VarChar(36)
  role_id       String    @db.VarChar(36)
  permission_id String    @db.VarChar(36)
  row_version   BigInt    @default(1)
  created_at    DateTime  @default(now()) @db.DateTime(3)
  updated_at    DateTime  @updatedAt @db.DateTime(3)
  deleted_at    DateTime? @db.DateTime(3)

  role       Role       @relation(fields: [role_id], references: [id])
  permission Permission @relation(fields: [permission_id], references: [id])

  @@unique([role_id, permission_id])
  @@map("role_permissions")
}

model Shift {
  id               String    @id @default(uuid()) @db.VarChar(36)
  code             String    @unique @db.VarChar(50)
  name             String    @db.VarChar(100)
  start_time       String    @db.VarChar(8) // TIME format handled as string HH:mm:ss
  end_time         String    @db.VarChar(8)
  crosses_midnight Boolean   @default(false)
  active           Boolean   @default(true)
  row_version      BigInt    @default(1)
  created_at       DateTime  @default(now()) @db.DateTime(3)
  updated_at       DateTime  @updatedAt @db.DateTime(3)
  deleted_at       DateTime? @db.DateTime(3)

  print_reports   PrintReport[]
  diecut_reports  DiecutReport[]
  rewind_reports  RewindReport[]
  packaging_reports PackagingReport[]
  kpis            ProductionKpiDaily[]

  @@map("shifts")
}

model User {
  id                  String    @id @default(uuid()) @db.VarChar(36)
  role_id             String    @db.VarChar(36)
  name                String    @db.VarChar(100)
  username            String    @unique @db.VarChar(50)
  password_hash       String    @db.VarChar(255)
  active              Boolean   @default(true)
  failed_login_attempts Int     @default(0)
  last_failed_login_at DateTime? @db.DateTime(3)
  locked_until        DateTime? @db.DateTime(3)
  last_login_at       DateTime? @db.DateTime(3)
  password_changed_at DateTime? @db.DateTime(3)
  row_version         BigInt    @default(1)
  created_at          DateTime  @default(now()) @db.DateTime(3)
  updated_at          DateTime  @updatedAt @db.DateTime(3)
  deleted_at          DateTime? @db.DateTime(3)

  role            Role               @relation(fields: [role_id], references: [id])
  assignedAreas   UserAssignedArea[]
  refreshTokens   RefreshToken[]
  sessions        UserSession[]
  sync_mutations  SyncMutationLog[]
  import_jobs     ImportJob[]
  clise_history   CliseHistory[]
  die_history     DieHistory[]
  incidents_rpt   Incident[]         @relation("ReportedBy")
  incidents_asgn  Incident[]         @relation("AssignedTo")
  capa_actions    CapaAction[]
  print_reports   PrintReport[]
  diecut_reports  DiecutReport[]
  rewind_reports  RewindReport[]
  packaging_reports PackagingReport[]
  file_objects    FileObject[]
  audit_logs      AuditLog[]         @relation("UserAudit")
  change_log      ChangeLog[]
  management_entries_entered WorkOrderManagementEntry[] @relation("ManagementEnteredBy")
  management_entries_exited  WorkOrderManagementEntry[] @relation("ManagementExitedBy")
  planning_entries_created   ProductionScheduleEntry[]  @relation("PlanningCreatedBy")
  planning_entries_updated   ProductionScheduleEntry[]  @relation("PlanningUpdatedBy")
  planning_revisions         ProductionScheduleRevision[]

  @@map("users")
}

model UserAssignedArea {
  id          String    @id @default(uuid()) @db.VarChar(36)
  user_id     String    @db.VarChar(36)
  area_id     String    @db.VarChar(36)
  row_version BigInt    @default(1)
  created_at  DateTime  @default(now()) @db.DateTime(3)
  updated_at  DateTime  @updatedAt @db.DateTime(3)
  deleted_at  DateTime? @db.DateTime(3)

  user User @relation(fields: [user_id], references: [id])
  area Area @relation(fields: [area_id], references: [id])

  @@unique([user_id, area_id])
  @@map("user_assigned_areas")
}

model SystemConfig {
  id                           String   @id @default(uuid()) @db.VarChar(36)
  plant_name                   String   @db.VarChar(150)
  auto_logout_minutes          Int      @default(30)
  password_expiry_warning_days Int      @default(7)
  password_policy_days         Int      @default(90)
  operator_message             String?  @db.Text
  timezone_name                String   @default("UTC") @db.VarChar(100)
  row_version                  BigInt   @default(1)
  created_at                   DateTime @default(now()) @db.DateTime(3)
  updated_at                   DateTime @updatedAt @db.DateTime(3)

  @@map("system_config")
}

model Machine {
  id          String    @id @default(uuid()) @db.VarChar(36)
  area_id     String    @db.VarChar(36)
  code        String    @unique @db.VarChar(50)
  name        String    @db.VarChar(100)
  type        String    @db.VarChar(50)
  status      String    @default("OPERATIVE") @db.VarChar(50) // ENUM in MySQL, String in Prisma for flexibility
  active      Boolean   @default(true)
  row_version BigInt    @default(1)
  created_at  DateTime  @default(now()) @db.DateTime(3)
  updated_at  DateTime  @updatedAt @db.DateTime(3)
  deleted_at  DateTime? @db.DateTime(3)

  area           Area                 @relation(fields: [area_id], references: [id])
  clise_history  CliseHistory[]
  die_history    DieHistory[]
  incidents      Incident[]
  print_reports  PrintReport[]
  diecut_reports DiecutReport[]
  rewind_reports RewindReport[]
  kpis           ProductionKpiDaily[]
  planning_entries ProductionScheduleEntry[]

  @@map("machines")
}

model RefreshToken {
  id                    String    @id @default(uuid()) @db.VarChar(36)
  user_id               String    @db.VarChar(36)
  session_id            String    @db.VarChar(36)
  token_hash            String    @unique @db.VarChar(255)
  expires_at            DateTime  @db.DateTime(3)
  rotated_from_token_id String?   @db.VarChar(36)
  revoked_at            DateTime? @db.DateTime(3)
  created_at            DateTime  @default(now()) @db.DateTime(3)

  user User @relation(fields: [user_id], references: [id])

  @@map("refresh_tokens")
}

model UserSession {
  id             String    @id @default(uuid()) @db.VarChar(36)
  user_id        String    @db.VarChar(36)
  device_id      String?   @db.VarChar(100)
  device_name    String?   @db.VarChar(150)
  device_type    String?   @db.VarChar(50)
  device_profile String?   @db.VarChar(50)
  ip_address     String?   @db.VarChar(45)
  user_agent     String?   @db.Text
  active         Boolean   @default(true)
  last_seen_at   DateTime? @db.DateTime(3)
  revoked_at     DateTime? @db.DateTime(3)
  created_at     DateTime  @default(now()) @db.DateTime(3)

  user      User       @relation(fields: [user_id], references: [id])
  auditLogs AuditLog[]

  @@index([user_id])
  @@index([active])
  @@map("user_sessions")
}

// =========================================================
// 2. AUDITORÍA, CAMBIOS Y PROCESOS
// =========================================================

model AuditLog {
  id                  BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id             String?  @db.VarChar(36)
  session_id          String?  @db.VarChar(36)
  user_name_snapshot  String?  @db.VarChar(100)
  role_code_snapshot  String?  @db.VarChar(50)
  entity              String   @db.VarChar(100)
  entity_id           String?  @db.VarChar(36)
  action              String   @db.VarChar(50) // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, IMPORT, EXPORT
  old_values          Json?
  new_values          Json?
  ip_address          String?  @db.VarChar(45)
  user_agent          String?  @db.Text
  correlation_id      String?  @db.VarChar(100)
  created_at          DateTime @default(now()) @db.DateTime(3)

  user    User?        @relation("UserAudit", fields: [user_id], references: [id])
  session UserSession? @relation(fields: [session_id], references: [id])

  @@index([created_at])
  @@index([entity])
  @@index([entity_id])
  @@index([user_id])
  @@map("audit_logs")
}

model ChangeLog {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  entity         String   @db.VarChar(100)
  entity_id      String   @db.VarChar(36)
  operation      String   @db.VarChar(50) // CREATE, UPDATE, DELETE
  row_version    BigInt
  changed_at     DateTime @default(now()) @db.DateTime(3)
  user_id        String?  @db.VarChar(36)
  correlation_id String?  @db.VarChar(100)

  user User? @relation(fields: [user_id], references: [id])

  @@index([changed_at, id])
  @@index([entity, entity_id])
  @@index([user_id])
  @@map("change_log")
}

model SyncMutationLog {
  mutation_id      String   @id @db.VarChar(36)
  client_id        String   @db.VarChar(100)
  device_profile   String?  @db.VarChar(50)
  user_id          String   @db.VarChar(36)
  entity           String   @db.VarChar(100)
  entity_id        String   @db.VarChar(36)
  action           String   @db.VarChar(50) // CREATE, UPDATE, DELETE
  status           String   @db.VarChar(50) // PROCESSED, CONFLICT, REJECTED
  request_payload  Json?
  response_payload Json?
  correlation_id   String?  @db.VarChar(100)
  processed_at     DateTime @default(now()) @db.DateTime(3)

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([entity])
  @@map("sync_mutation_log")
}

model ImportJob {
  id                 String    @id @default(uuid()) @db.VarChar(36)
  entity_name        String    @db.VarChar(100)
  file_name          String    @db.VarChar(255)
  file_hash          String?   @db.VarChar(64)
  file_url           String?   @db.VarChar(500)
  status             String    @default("PENDING") @db.VarChar(50) // PENDING, VALIDATING, READY, PROCESSING, COMPLETED, FAILED
  total_rows         Int       @default(0)
  valid_rows         Int       @default(0)
  invalid_rows       Int       @default(0)
  applied_rows       Int       @default(0)
  summary            Json?
  created_by_user_id String    @db.VarChar(36)
  correlation_id     String?   @db.VarChar(100)
  started_at         DateTime? @db.DateTime(3)
  finished_at        DateTime? @db.DateTime(3)
  created_at         DateTime  @default(now()) @db.DateTime(3)
  updated_at         DateTime  @updatedAt @db.DateTime(3)

  user                  User                   @relation(fields: [created_by_user_id], references: [id])
  workOrderImportRows   WorkOrderImportRow[]
  cliseImportRows       CliseImportRow[]
  dieImportRows         DieImportRow[]

  @@map("import_jobs")
}

model OutboxEvent {
  id             String    @id @default(uuid()) @db.VarChar(36)
  event_name     String    @db.VarChar(150)
  aggregate_type String    @db.VarChar(100)
  aggregate_id   String    @db.VarChar(36)
  payload        Json
  status         String    @default("PENDING") @db.VarChar(50) // PENDING, PUBLISHED, FAILED
  attempts       Int       @default(0)
  available_at   DateTime  @default(now()) @db.DateTime(3)
  published_at   DateTime? @db.DateTime(3)
  created_at     DateTime  @default(now()) @db.DateTime(3)

  @@index([status, available_at])
  @@map("outbox_events")
}

// =========================================================
// 3. ÓRDENES DE TRABAJO
// =========================================================

model WorkOrder {
  id                          String    @id @default(uuid()) @db.VarChar(36)
  ot_number                   String    @unique @db.VarChar(50)
  status                      String    @default("IMPORTED") @db.VarChar(50) // IMPORTED, PLANNED, IN_PRODUCTION, PARTIAL, COMPLETED, CANCELLED
  descripcion                 String?   @db.Text
  nro_cotizacion              String?   @db.VarChar(50)
  nro_ficha                   String?   @db.VarChar(50)
  pedido                      String?   @db.VarChar(50)
  orden_compra                String?   @db.VarChar(100)
  cliente_razon_social        String?   @db.VarChar(150)
  vendedor                    String?   @db.VarChar(100)
  fecha_pedido                DateTime? @db.Date
  fecha_entrega               DateTime? @db.Date
  fecha_ingreso_planta        DateTime? @db.Date
  fecha_programada_produccion DateTime? @db.Date
  cantidad_pedida             Decimal?  @db.Decimal(14, 2)
  unidad                      String?   @db.VarChar(20)
  material                    String?   @db.VarChar(150)
  ancho_mm                    Decimal?  @db.Decimal(12, 3)
  avance_mm                   Decimal?  @db.Decimal(12, 3)
  desarrollo_mm               Decimal?  @db.Decimal(12, 3)
  columnas                    Int?
  adhesivo                    String?   @db.VarChar(100)
  acabado                     String?   @db.VarChar(100)
  troquel                     String?   @db.VarChar(100)
  maquina_texto               String?   @db.VarChar(100)
  total_metros                Decimal?  @db.Decimal(14, 3)
  total_m2                    Decimal?  @db.Decimal(14, 3)
  observaciones_diseno        String?   @db.Text
  observaciones_cotizacion    String?   @db.Text
  raw_payload                 Json?
  import_hash                 String?   @db.VarChar(64)
  row_version                 BigInt    @default(1)
  created_at                  DateTime  @default(now()) @db.DateTime(3)
  updated_at                  DateTime  @updatedAt @db.DateTime(3)
  deleted_at                  DateTime? @db.DateTime(3)

  stock_items    StockItem[]
  incidents      Incident[]
  print_reports  PrintReport[]
  diecut_reports DiecutReport[]
  rewind_reports RewindReport[]
  packaging_reports PackagingReport[]
  management_entries WorkOrderManagementEntry[]
  planning_entries ProductionScheduleEntry[]

  @@index([updated_at])
  @@index([deleted_at])
  @@index([status])
  @@fulltext([ot_number, cliente_razon_social, descripcion, material, vendedor])
  @@map("work_orders")
}

model WorkOrderManagementEntry {
  id                 String    @id @default(uuid()) @db.VarChar(36)
  work_order_id      String    @db.VarChar(36)
  entered_at         DateTime  @default(now()) @db.DateTime(3)
  entered_by_user_id String    @db.VarChar(36)
  exited_at          DateTime? @db.DateTime(3)
  exited_by_user_id  String?   @db.VarChar(36)
  exit_action        String?   @db.VarChar(50)
  created_at         DateTime  @default(now()) @db.DateTime(3)
  updated_at         DateTime  @updatedAt @db.DateTime(3)

  work_order WorkOrder @relation(fields: [work_order_id], references: [id])
  entered_by User      @relation("ManagementEnteredBy", fields: [entered_by_user_id], references: [id])
  exited_by  User?     @relation("ManagementExitedBy", fields: [exited_by_user_id], references: [id])

  @@index([work_order_id, exited_at])
  @@index([entered_at])
  @@index([entered_by_user_id])
  @@index([exited_by_user_id])
  @@map("work_order_management_entries")
}

model ProductionScheduleEntry {
  id                 String    @id @default(uuid()) @db.VarChar(36)
  schedule_date      DateTime  @db.Date
  shift              String    @db.VarChar(20)
  area               String    @db.VarChar(50)
  machine_id         String    @db.VarChar(36)
  work_order_id      String    @db.VarChar(36)
  start_time         String    @db.VarChar(8)
  duration_minutes   Int
  operator_name      String?   @db.VarChar(100)
  notes              String?   @db.Text
  snapshot_payload   Json
  created_by_user_id String?   @db.VarChar(36)
  updated_by_user_id String?   @db.VarChar(36)
  row_version        BigInt    @default(1)
  created_at         DateTime  @default(now()) @db.DateTime(3)
  updated_at         DateTime  @updatedAt @db.DateTime(3)
  deleted_at         DateTime? @db.DateTime(3)

  machine     Machine                    @relation(fields: [machine_id], references: [id])
  work_order  WorkOrder                  @relation(fields: [work_order_id], references: [id])
  created_by  User?                      @relation("PlanningCreatedBy", fields: [created_by_user_id], references: [id])
  updated_by  User?                      @relation("PlanningUpdatedBy", fields: [updated_by_user_id], references: [id])
  revisions   ProductionScheduleRevision[]

  @@index([schedule_date, shift, area, deleted_at], map: "idx_pse_date_shift_area_del")
  @@index([machine_id, schedule_date, deleted_at], map: "idx_pse_machine_date_del")
  @@index([work_order_id, schedule_date, deleted_at], map: "idx_pse_wo_date_del")
  @@map("production_schedule_entries")
}

model ProductionScheduleRevision {
  id                 String   @id @default(uuid()) @db.VarChar(36)
  schedule_entry_id  String   @db.VarChar(36)
  revision_number    Int
  changed_by_user_id String?  @db.VarChar(36)
  change_reason      String?  @db.Text
  before_payload     Json
  after_payload      Json
  created_at         DateTime @default(now()) @db.DateTime(3)

  schedule_entry ProductionScheduleEntry @relation(fields: [schedule_entry_id], references: [id])
  changed_by     User?                   @relation(fields: [changed_by_user_id], references: [id])

  @@unique([schedule_entry_id, revision_number], map: "uq_psr_entry_revision")
  @@index([schedule_entry_id, created_at], map: "idx_psr_entry_created")
  @@map("production_schedule_revisions")
}

model WorkOrderImportRow {
  id                String   @id @default(uuid()) @db.VarChar(36)
  import_job_id     String   @db.VarChar(36)
  row_number        Int
  row_status        String   @default("PENDING") @db.VarChar(50) // PENDING, VALID, INVALID, APPLIED
  business_key      String?  @db.VarChar(100)
  raw_row           Json
  normalized_row    Json?
  validation_errors Json?
  created_at        DateTime @default(now()) @db.DateTime(3)
  updated_at        DateTime @updatedAt @db.DateTime(3)

  import_job ImportJob @relation(fields: [import_job_id], references: [id])

  @@index([import_job_id])
  @@map("work_order_import_rows")
}

// =========================================================
// 4. INVENTARIO
// =========================================================

model Clise {
  id                String    @id @default(uuid()) @db.VarChar(36)
  item_code         String    @unique @db.VarChar(100)
  ubicacion         String?   @db.VarChar(100)
  descripcion       String?   @db.Text
  cliente           String?   @db.VarChar(150)
  z_value           String?   @db.VarChar(50)
  estandar          String?   @db.VarChar(100)
  ancho_mm          Decimal?  @db.Decimal(12, 3)
  avance_mm         Decimal?  @db.Decimal(12, 3)
  columnas          Int?
  repeticiones      Int?
  numero_clises     Int?
  espesor_mm        Decimal?  @db.Decimal(10, 3)
  fecha_ingreso     DateTime? @db.Date
  observaciones     String?   @db.Text
  maquina_texto     String?   @db.VarChar(100)
  colores_json      Json?
  ficha_fler        String?   @db.VarChar(100)
  metros_acumulados Decimal   @default(0) @db.Decimal(14, 3)
  imagen_url        String?   @db.VarChar(500)
  raw_payload       Json?
  row_version       BigInt    @default(1)
  created_at        DateTime  @default(now()) @db.DateTime(3)
  updated_at        DateTime  @updatedAt @db.DateTime(3)
  deleted_at        DateTime? @db.DateTime(3)
  rack_id           String?   @db.VarChar(36)

  color_usage   CliseColorUsage[]
  die_links     CliseDieLink[]
  history       CliseHistory[]
  print_reports PrintReport[]
  rack          RackConfig?      @relation(fields: [rack_id], references: [id])

  @@index([updated_at])
  @@index([deleted_at])
  @@map("clises")
}

model CliseImportRow {
  id                String   @id @default(uuid()) @db.VarChar(36)
  import_job_id     String   @db.VarChar(36)
  row_number        Int
  row_status        String   @default("PENDING") @db.VarChar(50) // PENDING, VALID, INVALID, APPLIED
  business_key      String?  @db.VarChar(100)
  raw_row           Json
  normalized_row    Json?
  validation_errors Json?
  created_at        DateTime @default(now()) @db.DateTime(3)
  updated_at        DateTime @updatedAt @db.DateTime(3)

  import_job ImportJob @relation(fields: [import_job_id], references: [id])

  @@index([import_job_id])
  @@map("clise_import_rows")
}

model CliseColorUsage {
  id          String    @id @default(uuid()) @db.VarChar(36)
  clise_id    String    @db.VarChar(36)
  color_name  String    @db.VarChar(100)
  meters      Decimal   @default(0) @db.Decimal(14, 3)
  row_version BigInt    @default(1)
  created_at  DateTime  @default(now()) @db.DateTime(3)
  updated_at  DateTime  @updatedAt @db.DateTime(3)
  deleted_at  DateTime? @db.DateTime(3)

  clise Clise @relation(fields: [clise_id], references: [id])

  @@index([clise_id])
  @@map("clise_color_usage")
}

model Die {
  id                String    @id @default(uuid()) @db.VarChar(36)
  serie             String    @unique @db.VarChar(100)
  medida            String?   @db.VarChar(100)
  ubicacion         String?   @db.VarChar(100)
  ancho_mm          Decimal?  @db.Decimal(12, 3)
  avance_mm         Decimal?  @db.Decimal(12, 3)
  ancho_plg         Decimal?  @db.Decimal(12, 3)
  avance_plg        Decimal?  @db.Decimal(12, 3)
  z_value           String?   @db.VarChar(50)
  columnas          Int?
  repeticiones      Int?
  material          String?   @db.VarChar(100)
  forma             String?   @db.VarChar(100)
  cliente           String?   @db.VarChar(150)
  observaciones     String?   @db.Text
  fecha_ingreso     DateTime? @db.Date
  pb                String?   @db.VarChar(50)
  separacion_avance String?   @db.VarChar(50)
  estado            String?   @db.VarChar(50)
  cantidad          Int?
  almacen           String?   @db.VarChar(100)
  metros_acumulados Decimal   @default(0) @db.Decimal(14, 3)
  tipo_troquel      String?   @db.VarChar(100)
  raw_payload       Json?
  row_version       BigInt    @default(1)
  created_at        DateTime  @default(now()) @db.DateTime(3)
  updated_at        DateTime  @updatedAt @db.DateTime(3)
  deleted_at        DateTime? @db.DateTime(3)
  rack_id           String?   @db.VarChar(36)

  clise_links    CliseDieLink[]
  history        DieHistory[]
  print_reports  PrintReport[]
  diecut_reports DiecutReport[]
