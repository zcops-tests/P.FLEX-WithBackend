{
  "name": "p.flex",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "ng serve",
    "build": "ng build",
    "lint": "tsc --noEmit -p tsconfig.app.json",
    "test:frontend": "node --import tsx --test tests/frontend/modules/*.spec.ts tests/frontend/ot-import.component.spec.ts tests/frontend/orders-import.service.spec.ts tests/frontend/app-routes.spec.ts tests/frontend/feature-modules-smoke.spec.ts tests/frontend/access-admin-sidebar.behavior.spec.ts",
    "preview": "ng serve --configuration=production",
    "smoke:baseline:api": "node ./scripts/smoke-baseline.mjs",
    "regression:baseline": "npm run lint && npm run build && npm --prefix backend run build && npm --prefix backend run test:baseline"
  },
  "dependencies": {
    "@angular/common": "21.2.5",
    "@angular/compiler": "21.2.5",
    "@angular/core": "21.2.5",
    "@angular/forms": "21.2.5",
    "@angular/platform-browser": "21.2.5",
    "@angular/router": "21.2.5",
    "d3": "7.9.0",
    "html2canvas": "1.4.1",
    "jspdf": "4.2.1",
    "rxjs": "^7.8.2",
    "xlsx": "0.18.5",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular/build": "21.2.3",
    "@angular/cli": "21.2.3",
    "@angular/compiler-cli": "21.2.5",
    "@types/node": "^22.14.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9"
  }
}
